# Chronos API — environment example
# Copy to .env and fill in. None of these are required to build; only to run against real providers.

# --- Server ---
PORT=3000

# --- Database (Supabase / Postgres) ---
# Leave unset in W2 to skip Prisma connect at boot.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/chronos
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/chronos

# --- JWT ---
# Use long random strings (>= 32 bytes base64). Rotate per environment.
JWT_ACCESS_SECRET=change-me-access-32bytes-min
JWT_REFRESH_SECRET=change-me-refresh-32bytes-min

# --- Apple Sign-In ---
# Bundle identifier used as the audience ("aud") of Apple identity tokens.
APPLE_CLIENT_ID=com.chronos.app

# --- Google Sign-In ---
# Client IDs from Google Cloud Console (OAuth 2.0 credentials).
# W9 TODO: register each platform client and fill these in.
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_WEB=
