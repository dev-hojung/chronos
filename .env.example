# ---------- Shared ----------
NODE_ENV=development

# ---------- API (api/) ----------
# Supabase Postgres pooled connection (6543 for pooler, 5432 for direct)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Anthropic (Claude Sonnet 4.5)
ANTHROPIC_API_KEY="sk-ant-..."

# Redis (Upstash) — ad_token, rate limit, usage counter
REDIS_URL="rediss://default:[TOKEN]@[ENDPOINT].upstash.io:6379"

# OAuth
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# RevenueCat (entitlements webhook)
REVENUECAT_WEBHOOK_SECRET=""
REVENUECAT_API_KEY=""

# AdMob SSV verification
ADMOB_APP_ID="ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX"
ADMOB_PUBLIC_KEY_URL="https://www.gstatic.com/admob/reward/verifier-keys.json"

# Sentry
SENTRY_DSN=""

# ---------- App (app/) ----------
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"
EXPO_PUBLIC_POSTHOG_KEY=""
EXPO_PUBLIC_SENTRY_DSN=""
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID="ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX"
EXPO_PUBLIC_ADMOB_IOS_APP_ID="ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX"
EXPO_PUBLIC_REVENUECAT_IOS_KEY=""
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=""

# ---------- Web (web/) ----------
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_POSTHOG_KEY=""
